---
import { db, Image, User, eq, ne, and, isNotNull, isNull, sql } from "astro:db";
import { thumborClean } from "@/utils/thumbor.util";

interface Props {
  initialImageUrl?: string | null;
  initialImageId?: string | null;
}

let { initialImageUrl = null, initialImageId = null } = Astro.props;

if (!initialImageUrl) {
  const jsDay = new Date().getDay();
  const fridayFilter = jsDay === 5
    ? eq(Image.dayOfWeek, "5")
    : ne(Image.dayOfWeek, "5");

  const img = await db
    .select({ id: Image.id, ownerId: Image.ownerId })
    .from(Image)
    .where(and(isNotNull(Image.approvedId), isNull(Image.deletedAt), fridayFilter))
    .orderBy(sql`random()`)
    .limit(1)
    .get();

  if (img) {
    const owner = await db
      .select({ nickname: User.nickname })
      .from(User)
      .where(eq(User.id, img.ownerId))
      .get();
    initialImageUrl = thumborClean(img.id, owner?.nickname || "user");
    initialImageId = img.id;
  }
}
---

{initialImageUrl && (
  <div class="w-full max-w-lg mt-4" id="friland-container" data-image-id={initialImageId}>
    <div class="card bg-base-200 shadow-lg overflow-hidden">
      <figure class="relative">
        <img
          id="friland-img"
          src={initialImageUrl}
          alt="Friland"
          class="w-full aspect-video object-cover transition-opacity duration-300"
        />
      </figure>
      <div class="flex justify-between items-center p-3">
        <button id="friland-copy" class="btn btn-ghost btn-sm">Copiaza</button>
        <button id="friland-next" class="btn btn-primary btn-sm">Urmatoarea</button>
      </div>
    </div>
  </div>
)}

<script>
  import { actions } from "astro:actions";

  const container = document.getElementById("friland-container");
  const nextBtn = document.getElementById("friland-next");
  const copyBtn = document.getElementById("friland-copy");
  const img = document.getElementById("friland-img") as HTMLImageElement | null;

  if (nextBtn && img && container) {
    nextBtn.addEventListener("click", async () => {
      nextBtn.classList.add("loading");
      const { data } = await actions.randomImage();
      if (data?.url && data?.id) {
        container.dataset.imageId = data.id;
        img.style.opacity = "0";
        const newImg = new Image();
        newImg.onload = () => {
          img.src = data.url;
          img.style.opacity = "1";
        };
        newImg.src = data.url;
      }
      nextBtn.classList.remove("loading");
    });
  }

  if (copyBtn && container) {
    copyBtn.addEventListener("click", async () => {
      const imageId = container.dataset.imageId;
      if (!imageId) return;
      const url = `${window.location.origin}?q=${imageId}`;
      await navigator.clipboard.writeText(url);
      const original = copyBtn.textContent;
      copyBtn.textContent = "Copiat!";
      setTimeout(() => { copyBtn.textContent = original; }, 1500);
    });
  }
</script>
