---
import { Icon } from "astro-icon/components";
---

<footer class="sticky top-[100vh] print:hidden w-full py-6 px-6 bg-neutral text-neutral-content">
    <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4 px-6">
        <aside class="text-center sm:text-left">
            <a href="/" class="font-lobster text-xl">iivineri</a>
            <p class="text-sm opacity-70">Pentru că vinerea nu se face deploy</p>
        </aside>
        <nav class="flex items-center gap-4">
          <a href="https://github.com/acayseth/iivineri" target="_blank" rel="noopener" aria-label="GitHub">
            <Icon name="simple-icons:github" class="w-6 h-6 fill-current" />
          </a>
          <a href="/about-us" class="text-sm opacity-70 hover:opacity-100 transition-opacity">Despre noi</a>
        </nav>
    </div>
</footer>
