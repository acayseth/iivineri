---
import "@/assets/global.css"
import Navbar from "@/components/Navbar.astro"
import Footer from "@/components/Footer.astro"
import { SEO } from "astro-seo";
import { db, User, eq, and, isNull } from "astro:db";

interface Props {
  title?: string;
  description?: string;
}

const { title = "iivineri", description = "Pentru ca vinerea nu se deploy" } = Astro.props;
const theme = Astro.cookies.get("theme")?.value ?? "dark";

const userId = await Astro.session?.get("userId");
let currentUser: { nickname: string } | null = null;
if (userId) {
  const found = await db
    .select({ nickname: User.nickname })
    .from(User)
    .where(and(eq(User.id, userId), isNull(User.deletedAt)))
    .get();
  currentUser = found ?? null;
}
const fullTitle = title === "iivineri" ? title : `${title} | iivineri`;
---

<!doctype html>
<html lang="ro" data-theme={theme}>
	<head>
	    <meta charset="UTF-8" />
	    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
	    <meta name="theme-color" content={theme === "dark" ? "#1D232A" : "#ffffff"} />
		<SEO
            title={fullTitle}
            description={description}
            openGraph={{
                basic: {
                  title: fullTitle,
                  type: "website",
                  image: "/favicon.svg",
                }
            }}
            extend={{
                link: [{ rel: "icon", href: "/favicon.svg" }],
            }}
        />
	</head>
	<body class="min-h-screen font-sans">
	    <Navbar theme={theme} user={currentUser} />
		<slot />
		<Footer />
	</body>
</html>
