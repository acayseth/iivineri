---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="500">
  <main class="flex flex-col items-center justify-center min-h-[calc(100vh-8rem)] px-4 text-center gap-4">
    <h1 class="text-8xl font-bold font-lobster text-error">500</h1>
    <p class="text-xl text-base-content/60">Ceva nu a mers bine</p>
    <p class="text-base-content/40 text-sm">Incearca din nou mai tarziu</p>
    <a href="/" class="btn btn-primary mt-4">Inapoi acasa</a>
  </main>
</Layout>
