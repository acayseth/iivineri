---
import Layout from "@/layouts/Layout.astro";
import ImageUploader from "@/components/ImageUploader";

const userId = await Astro.session?.get("userId");
if (!userId) {
  return Astro.redirect("/sign-in");
}
---

<Layout title="Incarca imagini">
  <main class="flex items-center justify-center px-4">
    <div class="w-full max-w-7xl">
      <div class="card bg-base-200 p-8 shadow-lg">
        <h1 class="text-2xl font-bold mb-6">Incarca imagini</h1>
        <ImageUploader client:load />
      </div>
    </div>
  </main>
</Layout>
